<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBlock">
    <Setter Property="FontFamily" Value="Calibri" />
  </Style>

  <Style Selector="Button">
    <Setter Property="FontFamily" Value="Calibri" />
  </Style>

  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.h3">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.h4">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.h5">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <!-- ─── Glass Card ─── -->
  <Style Selector="Border.glass-card">
    <Setter Property="Background" Value="#FF161B22" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <!-- ─── Section Header ─── -->
  <Style Selector="TextBlock.section-header">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#E0E4EB" />
    <Setter Property="LetterSpacing" Value="1" />
    <!-- TextTransform not available; use uppercase strings directly -->
  </Style>

  <!-- ─── Metric Value ─── -->
  <Style Selector="TextBlock.metric-value">
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontFamily" Value="Calibri" />
    <Setter Property="Foreground" Value="#E0E4EB" />
  </Style>

  <!-- ─── Metric Label ─── -->
  <Style Selector="TextBlock.metric-label">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#E0E4EB" />
    <Setter Property="LetterSpacing" Value="1" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <!-- ─── Pedestrian row ─── -->
  <Style Selector="Border.ped-row">
    <Setter Property="Background" Value="#FF1B212A" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

</Styles>
