<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:icons="https://github.com/projektanker/icons.avalonia"
    xmlns:local="using:AvaloniaExercise"
    xmlns:vm="using:AvaloniaExercise.ViewModels"
    xmlns:model="using:AvaloniaExercise.Models"
    xmlns:i="https://github.com/projektanker/icons.avalonia"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="AvaloniaExercise.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="Real-Time Pedestrian Control System"
    RequestedThemeVariant="Dark"
    Width="1440"
    Height="820"
    MinWidth="1200"
    MinHeight="700"
    Background="#0A0E15"
    FontFamily="Calibri">

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Calibri" />
    </Style>

    <Style Selector="Button">
      <Setter Property="FontFamily" Value="Calibri" />
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.hero-title">
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="0.2" />
    </Style>

    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.h3">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.h4">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.h5">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="Border.glass-card">
      <Setter Property="Background" Value="#FF161B22" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="TextBlock.section-header">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#E0E4EB" />
      <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <Style Selector="TextBlock.metric-value">
      <Setter Property="FontSize" Value="32" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontFamily" Value="Calibri" />
      <Setter Property="Foreground" Value="#E0E4EB" />
    </Style>

    <Style Selector="TextBlock.metric-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#E0E4EB" />
      <Setter Property="LetterSpacing" Value="1" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.ped-row">
      <Setter Property="Background" Value="#FF1B212A" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.species-badge">
      <Setter Property="Background" Value="#FF263142" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.crossing-avatar">
      <Setter Property="Background" Value="#FF2B3745" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Margin" Value="3" />
    </Style>

    <Style Selector="Border.motion-banner">
      <Setter Property="Background" Value="#C8182430" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="BorderBrush" Value="#22314256" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.signal-housing">
      <Setter Property="Width" Value="172" />
      <Setter Property="Background" Value="#FF1B212A" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="BorderBrush" Value="#22314256" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.signal-state-primary">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="LetterSpacing" Value="0.8" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.count-card">
      <Setter Property="Background" Value="#FF1B212A" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style Selector="TextBlock.signal-meta-label">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#8FA0B5" />
      <Setter Property="LetterSpacing" Value="0.8" />
    </Style>
  </Window.Styles>

  <Window.Resources>
    <local:TriggerLabelConverter x:Key="TriggerLabelConv" />
    <local:IsIdleConverter x:Key="IsIdleConv" />
    <local:TriggerGlowConverter x:Key="TriggerGlowConv" />
    <local:TriggerTextBrushConverter x:Key="TriggerTextConv" />
    <local:NotIdleConverter x:Key="NotIdleConv" />
    <local:VehicleStatusTextConverter x:Key="VehicleStatusTextConv" />
    <local:VehicleStatusBrushConverter x:Key="VehicleStatusBrushConv" />
    <local:PedestrianStatusTextConverter x:Key="PedStatusTextConv" />
    <local:PedestrianStatusBrushConverter x:Key="PedStatusBrushConv" />
    <local:CarBrushConverter x:Key="CarBrushConv" />
    <local:PedestrianIconBrushConverter x:Key="PedIconBrushConv" />
    <local:ZebraOpacityConverter x:Key="ZebraOpacityConv" />
    <local:PedBadgeTextConverter x:Key="PedBadgeTextConv" />
    <local:PedStatusLabelConverter x:Key="PedStatusLabelConv" />
    <local:PeakHourBgConverter x:Key="PeakBgConv" />
    <local:PeakHourTextConverter x:Key="PeakTextConv" />
    <local:MiniSignalBrushConverter x:Key="MiniSignalConv" />
    <local:SignalLightBrushConverter x:Key="SignalBrushConv" />
    <local:SignalLabelBrushConverter x:Key="SignalLabelBrushConv" />
    <local:SignalLightActiveConverter x:Key="SignalActiveConv" />
    <local:CountdownVisibilityConverter x:Key="CountdownVisConv" />
    <local:ProgressRingStrokeConverter x:Key="ProgressRingStrokeConv" />
    <local:PedestrianSpeciesIconConverter x:Key="SpeciesIconConv" />
    <local:IsActiveCrossingConverter x:Key="IsActiveCrossingConv" />
  </Window.Resources>

  <Grid Margin="24" RowDefinitions="Auto,*,Auto">

    <!-- ═══════════ TOP BAR ═══════════ -->
    <Border Grid.Row="0" Classes="glass-card" Padding="24,16" Margin="0,0,0,16">
      <DockPanel>
           <TextBlock Text="Real-Time Pedestrian Control System"
                  Classes="hero-title"
                  Foreground="#E0E4EB"
                  VerticalAlignment="Center" />

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Right">
          <!-- Peak Hour -->
          <Border CornerRadius="8" Padding="16,8"
                  Background="{Binding PeakHourActive, Converter={StaticResource PeakBgConv}}"
              BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <TextBlock Text="Peak Hour" Classes="h5"
                         Foreground="{Binding PeakHourActive, Converter={StaticResource PeakTextConv}}" />
            </StackPanel>
          </Border>
          <!-- Clock -->
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <i:Icon Value="fa-solid fa-clock"
                    FontSize="12"
                    Foreground="#E0E4EB"
                    VerticalAlignment="Center" />
            <TextBlock Text="Live Time" Classes="h5" Foreground="#E0E4EB" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentTime}" Classes="h4"
                       Foreground="#E0E4EB" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══════════ BOTTOM METRICS ROW ═══════════ -->
    <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" Margin="0,16,0,0">
      <!-- Crossings Today -->
      <Border Grid.Column="0" Classes="glass-card" Margin="0,0,16,0">
        <StackPanel>
          <TextBlock Text="CROSSINGS TODAY" Classes="metric-label" />
          <TextBlock Text="{Binding TotalCrossings}" Classes="metric-value" />
        </StackPanel>
      </Border>
      <!-- Avg Wait Time -->
      <Border Grid.Column="1" Classes="glass-card" Margin="0,0,16,0">
        <StackPanel>
          <TextBlock Text="AVG WAIT TIME" Classes="metric-label" />
          <TextBlock Text="{Binding AvgWaitTime, StringFormat={}{0:F1}s}" Classes="metric-value" />
        </StackPanel>
      </Border>
      <!-- Queue / Crossing -->
      <Border Grid.Column="2" Classes="glass-card" Margin="0,0,16,0">
        <StackPanel>
          <TextBlock Text="QUEUE" Classes="metric-label" />
          <TextBlock Text="{Binding QueueSize}" Classes="metric-value" />
        </StackPanel>
      </Border>
      <!-- Now Crossing -->
      <Border Grid.Column="3" Classes="glass-card">
        <StackPanel>
          <TextBlock Text="CROSSING" Classes="metric-label" />
          <TextBlock Text="{Binding CrossingCount}" Classes="metric-value" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- ═══════════ MAIN CONTENT (3-column) ═══════════ -->
    <Grid Grid.Row="1" ColumnDefinitions="280,*,320">

      <!-- ─── LEFT COLUMN: Traffic Signal + Crossing Control ─── -->
      <Grid Grid.Column="0" RowDefinitions="*,Auto" Margin="0,0,16,0">

        <!-- ── Traffic Signal Panel (flex-[3]) ── -->
        <Border Grid.Row="0" Classes="glass-card" MinHeight="360">
          <StackPanel Spacing="20">
            <TextBlock Text="TRAFFIC SIGNAL" Classes="section-header" />

            <!-- Signal Housing -->
            <Border Classes="signal-housing" HorizontalAlignment="Center">
              <StackPanel Spacing="12" HorizontalAlignment="Center">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                  <Grid Width="68" Height="68">
                    <Ellipse Width="60" Height="60"
                             Fill="#33FF4848"
                             Opacity="0.3">
                      <Ellipse.IsVisible>
                        <MultiBinding Converter="{StaticResource SignalActiveConv}">
                          <Binding Path="CrossingState" />
                          <Binding Source="Red" />
                        </MultiBinding>
                      </Ellipse.IsVisible>
                      <Ellipse.Styles>
                        <Style Selector="Ellipse">
                          <Style.Animations>
                            <Animation Duration="0:0:1.1" IterationCount="Infinite" PlaybackDirection="Alternate">
                              <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="0.2" />
                              </KeyFrame>
                              <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="0.85" />
                              </KeyFrame>
                            </Animation>
                          </Style.Animations>
                        </Style>
                      </Ellipse.Styles>
                    </Ellipse>
                    <Ellipse Width="58" Height="58" Fill="#FF0E1117" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <MultiBinding Converter="{StaticResource SignalBrushConv}">
                          <Binding Path="CrossingState" />
                          <Binding Source="Red" />
                        </MultiBinding>
                      </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="{Binding Countdown}">
                      <TextBlock.IsVisible>
                        <MultiBinding Converter="{StaticResource CountdownVisConv}">
                          <Binding Path="CrossingState" />
                          <Binding Path="Countdown" />
                          <Binding Source="Red" />
                        </MultiBinding>
                      </TextBlock.IsVisible>
                    </TextBlock>
                  </Grid>
                  <TextBlock Text="Stop" Classes="signal-state-primary" HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                      <MultiBinding Converter="{StaticResource SignalLabelBrushConv}">
                        <Binding Path="CrossingState" />
                        <Binding Source="Red" />
                      </MultiBinding>
                    </TextBlock.Foreground>
                  </TextBlock>
                </StackPanel>

                <StackPanel Spacing="4" HorizontalAlignment="Center">
                  <Grid Width="68" Height="68">
                    <Ellipse Width="60" Height="60"
                             Fill="#33FFC42E"
                             Opacity="0.3">
                      <Ellipse.IsVisible>
                        <MultiBinding Converter="{StaticResource SignalActiveConv}">
                          <Binding Path="CrossingState" />
                          <Binding Source="Amber" />
                        </MultiBinding>
                      </Ellipse.IsVisible>
                      <Ellipse.Styles>
                        <Style Selector="Ellipse">
                          <Style.Animations>
                            <Animation Duration="0:0:1.1" IterationCount="Infinite" PlaybackDirection="Alternate">
                              <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="0.2" />
                              </KeyFrame>
                              <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="0.85" />
                              </KeyFrame>
                            </Animation>
                          </Style.Animations>
                        </Style>
                      </Ellipse.Styles>
                    </Ellipse>
                    <Ellipse Width="58" Height="58" Fill="#FF0E1117" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <MultiBinding Converter="{StaticResource SignalBrushConv}">
                          <Binding Path="CrossingState" />
                          <Binding Source="Amber" />
                        </MultiBinding>
                      </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="{Binding Countdown}">
                      <TextBlock.IsVisible>
                        <MultiBinding Converter="{StaticResource CountdownVisConv}">
                          <Binding Path="CrossingState" />
                          <Binding Path="Countdown" />
                          <Binding Source="Amber" />
                        </MultiBinding>
                      </TextBlock.IsVisible>
                    </TextBlock>
                  </Grid>
                  <TextBlock Text="Caution" Classes="signal-state-primary" HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                      <MultiBinding Converter="{StaticResource SignalLabelBrushConv}">
                        <Binding Path="CrossingState" />
                        <Binding Source="Amber" />
                      </MultiBinding>
                    </TextBlock.Foreground>
                  </TextBlock>
                </StackPanel>

                <StackPanel Spacing="4" HorizontalAlignment="Center">
                  <Grid Width="68" Height="68">
                    <Ellipse Width="60" Height="60"
                             Fill="#3334D399"
                             Opacity="0.3">
                      <Ellipse.IsVisible>
                        <MultiBinding Converter="{StaticResource SignalActiveConv}">
                          <Binding Path="CrossingState" />
                          <Binding Source="Green" />
                        </MultiBinding>
                      </Ellipse.IsVisible>
                      <Ellipse.Styles>
                        <Style Selector="Ellipse">
                          <Style.Animations>
                            <Animation Duration="0:0:1.1" IterationCount="Infinite" PlaybackDirection="Alternate">
                              <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="0.2" />
                              </KeyFrame>
                              <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="0.85" />
                              </KeyFrame>
                            </Animation>
                          </Style.Animations>
                        </Style>
                      </Ellipse.Styles>
                    </Ellipse>
                    <Ellipse Width="58" Height="58" Fill="#FF0E1117" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <MultiBinding Converter="{StaticResource SignalBrushConv}">
                          <Binding Path="CrossingState" />
                          <Binding Source="Green" />
                        </MultiBinding>
                      </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="{Binding Countdown}">
                      <TextBlock.IsVisible>
                        <MultiBinding Converter="{StaticResource CountdownVisConv}">
                          <Binding Path="CrossingState" />
                          <Binding Path="Countdown" />
                          <Binding Source="Green" />
                        </MultiBinding>
                      </TextBlock.IsVisible>
                    </TextBlock>
                  </Grid>
                  <TextBlock Text="Go" Classes="signal-state-primary" HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                      <MultiBinding Converter="{StaticResource SignalLabelBrushConv}">
                        <Binding Path="CrossingState" />
                        <Binding Source="Green" />
                      </MultiBinding>
                    </TextBlock.Foreground>
                  </TextBlock>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- ── Crossing Control (flex-[2]) ── -->
        <Border Grid.Row="1" Classes="glass-card" MinHeight="220" Margin="0,16,0,0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="CROSSING CONTROL" Classes="section-header" Margin="0,0,0,16" />

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="112" Height="112">
              <!-- Progress ring background -->
              <Ellipse Width="112" Height="112" StrokeThickness="3"
                       Stroke="#20303541" Fill="Transparent"
                       IsVisible="{Binding CrossingState, Converter={StaticResource NotIdleConv}}" />
              <!-- Progress ring foreground (simplified — full arc logic needs code-behind for StrokeDashArray) -->
              <Ellipse Width="112" Height="112" StrokeThickness="3"
                       Fill="Transparent"
                       Stroke="{Binding CrossingState, Converter={StaticResource ProgressRingStrokeConv}}"
                       IsVisible="{Binding CrossingState, Converter={StaticResource NotIdleConv}}" />
              <!-- Button -->
              <Button Command="{Binding TriggerCrossingCommand}"
                      IsEnabled="{Binding CrossingState, Converter={StaticResource IsIdleConv}}"
                    Width="112" Height="112" CornerRadius="56"
                  Padding="16"
                      Background="{Binding CrossingState, Converter={StaticResource TriggerGlowConv}}"
                      BorderThickness="0"
                      HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                 <TextBlock Text="{Binding CrossingState, Converter={StaticResource TriggerLabelConv}}" Classes="h4"
                           Foreground="{Binding CrossingState, Converter={StaticResource TriggerTextConv}}"
                   Width="72"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   LineHeight="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
              </Button>
            </Grid>
          </DockPanel>
        </Border>
      </Grid>

      <!-- ─── CENTER COLUMN: Crossing Zone ─── -->
      <Border Grid.Column="1" Classes="glass-card" Background="#FF161B22" Margin="0,0,16,0">
        <Grid RowDefinitions="Auto,*">
          <!-- Header -->
          <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="CROSSING ZONE" Classes="section-header h4" Margin="0,0,0,8" Foreground="#F0F1F5" />
            <Grid ColumnDefinitions="*,*">
              <!-- Vehicle signals -->
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                <TextBlock Text="VEHICLES" Classes="h5" Foreground="#FFFFFF"
                           VerticalAlignment="Center" />
                <Border Background="#FF1B212A" CornerRadius="8" Padding="8">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding CrossingState, Converter={StaticResource MiniSignalConv}, ConverterParameter=VehicleRed}" />
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding CrossingState, Converter={StaticResource MiniSignalConv}, ConverterParameter=VehicleAmber}" />
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding CrossingState, Converter={StaticResource MiniSignalConv}, ConverterParameter=VehicleGreen}" />
                  </StackPanel>
                </Border>
                <TextBlock Text="{Binding CrossingState, Converter={StaticResource VehicleStatusTextConv}}" Classes="h5"
                           Foreground="{Binding CrossingState, Converter={StaticResource VehicleStatusBrushConv}}"
                           VerticalAlignment="Center" />
              </StackPanel>

              <!-- Pedestrian signals -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <TextBlock Text="PEDESTRIANS" Classes="h5" Foreground="#FFFFFF"
                           VerticalAlignment="Center" />
                <Border Background="#FF1B212A" CornerRadius="8" Padding="8">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding CrossingState, Converter={StaticResource MiniSignalConv}, ConverterParameter=PedGreen}" />
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding CrossingState, Converter={StaticResource MiniSignalConv}, ConverterParameter=PedRed}" />
                  </StackPanel>
                </Border>
                <TextBlock Text="{Binding CrossingState, Converter={StaticResource PedStatusTextConv}}" Classes="h5"
                           Foreground="{Binding CrossingState, Converter={StaticResource PedStatusBrushConv}}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </StackPanel>

          <!-- ── Road Scene ── -->
          <Border Grid.Row="1" CornerRadius="12" ClipToBounds="True" Margin="0,8,0,0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1B222D" Offset="0" />
                <GradientStop Color="#131A22" Offset="0.18" />
                <GradientStop Color="#10151C" Offset="0.18" />
                <GradientStop Color="#10151C" Offset="0.82" />
                <GradientStop Color="#1B222D" Offset="0.82" />
                <GradientStop Color="#1F2833" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="72,*,72">
              <!-- LEFT SIDEWALK -->
              <Border Grid.Column="0" Background="#262F3B">
                <Grid Margin="8,16,8,16">
                  <ItemsControl ItemsSource="{Binding LeftSidePedestrians}" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="56">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="model:Pedestrian">
                        <Border Classes="crossing-avatar">
                          <i:Icon Value="{Binding Species, Converter={StaticResource SpeciesIconConv}}"
                                  FontSize="18"
                                  Margin="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{ReflectionBinding $parent[Window].DataContext.CrossingState, Converter={StaticResource PedIconBrushConv}}" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>

              <!-- ROAD -->
              <Grid Grid.Column="1">
                <Grid.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#242B34" Offset="0" />
                    <GradientStop Color="#181E26" Offset="0.5" />
                    <GradientStop Color="#242B34" Offset="1" />
                  </LinearGradientBrush>
                </Grid.Background>
                <Rectangle Fill="#FFFFFF" Height="3" VerticalAlignment="Top" Margin="0,22,0,0" Opacity="0.14" />
                <Rectangle Fill="#FFFFFF" Height="3" VerticalAlignment="Bottom" Margin="0,0,0,22" Opacity="0.14" />
                <Grid ColumnDefinitions="*,2,*">
                  <!-- Left lane (Southbound) -->
                  <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto" HorizontalAlignment="Stretch">
                    <TextBlock Text="↓" Classes="h4" Foreground="#E0E4EB" HorizontalAlignment="Center" Margin="0,16,0,0" Opacity="0.45" />
                        <!-- Car icon (southbound - top view) -->
                    <i:Icon Grid.Row="2"
                          Value="fa-solid fa-car-rear"
                            FontSize="24"
                            HorizontalAlignment="Center"
                          Foreground="{Binding CrossingState, Converter={StaticResource CarBrushConv}}"
                                Margin="0,0,0,8"
                            RenderTransform="rotate(180deg)" />
                              <TextBlock Grid.Row="3" Text="↓" Classes="h4" Foreground="#E0E4EB" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.45" />
                  </Grid>

                  <!-- Center divider (dotted yellow) -->
                  <Line Grid.Column="1"
                    StartPoint="0,0" EndPoint="0,1"
                    Stretch="Fill"
                    Stroke="#6B7280"
                    StrokeThickness="2"
                    StrokeDashArray="4,6"
                    Margin="0,16" />

                  <!-- Right lane (Northbound) -->
                  <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*,Auto" HorizontalAlignment="Stretch">
                    <TextBlock Text="↑" Classes="h4" Foreground="#E0E4EB" HorizontalAlignment="Center" Margin="0,16,0,0" Opacity="0.45" />
                        <!-- Car icon (northbound - top view) -->
                    <i:Icon Grid.Row="1"
                          Value="fa-solid fa-car-rear"
                            FontSize="24"
                            HorizontalAlignment="Center"
                          Foreground="{Binding CrossingState, Converter={StaticResource CarBrushConv}}"
                            Margin="0,8,0,0" />
                    <TextBlock Grid.Row="3" Text="↑" Classes="h4" Foreground="#E0E4EB" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.45" />
                  </Grid>
                </Grid>

                <!-- Zebra crossing -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0,16"
                      Height="132"
                      ColumnDefinitions="2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*,0.5*,2*"
                      Opacity="{Binding CrossingState, Converter={StaticResource ZebraOpacityConv}}">
                    <Rectangle Grid.Column="0" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="2" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="4" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="6" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="8" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="10" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="12" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="14" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="16" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="18" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="20" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="22" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="24" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="26" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                    <Rectangle Grid.Column="28" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
                </Grid>

                <Border Classes="motion-banner"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="22,-34,0,0"
                        IsVisible="{Binding CrossingState, Converter={StaticResource IsActiveCrossingConv}}">
                  <TextBlock Text="Left to Right  →  →  →" Classes="h5" Foreground="#A8E4C8">
                    <TextBlock.Styles>
                      <Style Selector="TextBlock">
                        <Style.Animations>
                          <Animation Duration="0:0:1.1" IterationCount="Infinite" PlaybackDirection="Alternate">
                            <KeyFrame Cue="0%">
                              <Setter Property="Opacity" Value="0.35" />
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                              <Setter Property="Opacity" Value="1" />
                            </KeyFrame>
                          </Animation>
                        </Style.Animations>
                      </Style>
                    </TextBlock.Styles>
                  </TextBlock>
                </Border>

                <Border Classes="motion-banner"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,34,22,0"
                        IsVisible="{Binding CrossingState, Converter={StaticResource IsActiveCrossingConv}}">
                  <TextBlock Text="←  ←  ←  Right to Left" Classes="h5" Foreground="#A8E4C8">
                    <TextBlock.Styles>
                      <Style Selector="TextBlock">
                        <Style.Animations>
                          <Animation Duration="0:0:1.1" IterationCount="Infinite" PlaybackDirection="Alternate">
                            <KeyFrame Cue="0%">
                              <Setter Property="Opacity" Value="1" />
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                              <Setter Property="Opacity" Value="0.35" />
                            </KeyFrame>
                          </Animation>
                        </Style.Animations>
                      </Style>
                    </TextBlock.Styles>
                  </TextBlock>
                </Border>
              </Grid>


              <!-- RIGHT SIDEWALK -->
              <Border Grid.Column="2" Background="#262F3B">
                <Grid Margin="8,16,8,16">
                  <ItemsControl ItemsSource="{Binding RightSidePedestrians}" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="56">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="model:Pedestrian">
                        <Border Classes="crossing-avatar">
                          <i:Icon Value="{Binding Species, Converter={StaticResource SpeciesIconConv}}"
                                  FontSize="18"
                                  Margin="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{ReflectionBinding $parent[Window].DataContext.CrossingState, Converter={StaticResource PedIconBrushConv}}" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <!-- ─── RIGHT COLUMN: Pedestrian List ─── -->
      <Border Grid.Column="2" Classes="glass-card">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="PEDESTRIANS" Classes="section-header" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
              <Border Grid.Column="0" Classes="count-card">
                <StackPanel Spacing="4">
                  <TextBlock Text="PEDESTRIANS" Classes="signal-meta-label" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <i:Icon Value="fa-solid fa-person" FontSize="12" Foreground="#9FDEC4" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding HumanCount}" Classes="h3" Foreground="#F5F7FA" />
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Classes="count-card">
                <StackPanel Spacing="4">
                  <TextBlock Text="ANIMALS" Classes="signal-meta-label" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <i:Icon Value="fa-solid fa-paw" FontSize="12" Foreground="#F2D08A" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AnimalCount}" Classes="h3" Foreground="#F5F7FA" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>

          <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <ItemsControl ItemsSource="{Binding Pedestrians}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="model:Pedestrian">
                  <Border Classes="ped-row">
                    <DockPanel>
                      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Classes="species-badge">
                          <i:Icon Value="{Binding Species, Converter={StaticResource SpeciesIconConv}}"
                                  FontSize="14"
                                  Foreground="#F5F7FA"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" Classes="h4" Foreground="#E0E4EB"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                      </StackPanel>
                      <TextBlock DockPanel.Dock="Right"
                             Text="{Binding Status, Converter={StaticResource PedStatusLabelConv}}"
                             Classes="h5"
                             Foreground="{Binding Status, Converter={StaticResource PedBadgeTextConv}}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center" />
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </Grid>
</Window>

